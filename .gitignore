received_files/
transient_uploads/
*.log

# Local capture/extract artifacts
capture_upload.pcapng
extracted_from_pcap/

# Build and packaging artifacts (PyInstaller)
build/*
!build/*.ps1
!build/*.bat
dist/
*.manifest
*.pkg
*.toc
*.pyz

# Installer output artifacts
installer/Output/
installer/build/
installer/dist/
*.msi
